---
import type { TrustPoint } from "@/data/pages/home";

interface Props {
  heading?: string;
  items: TrustPoint[];
}

const { heading, items } = Astro.props;
---

<div class="text-center">
  {heading && <h2 class="mb-8 text-2xl font-semibold tracking-tight">{heading}</h2>}
  <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3 text-left">
    {items.map((item) => (
      <li class="flex items-center gap-4 px-5 py-4 rounded-xl bg-white border border-[rgb(var(--color-border))] transition-[border-color,box-shadow] duration-200 hover:border-[rgb(var(--color-border-strong))] hover:shadow-sm">
        {item.icon && (
          <span
            class="inline-flex items-center justify-center w-8 h-8 shrink-0 rounded-full bg-[rgb(var(--color-surface-alt))] text-[rgb(var(--color-accent))] font-bold text-base leading-none"
            aria-hidden="true"
          >
            {item.icon}
          </span>
        )}
        <span class="text-base font-medium leading-snug">{item.text}</span>
      </li>
    ))}
  </ul>
</div>
