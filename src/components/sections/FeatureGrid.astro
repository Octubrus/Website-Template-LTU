---
import SectionHeading from "@/components/ui/SectionHeading.astro";

interface FeatureItem {
  title: string;
  description: string;
  icon?: string;
  meta?: string;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  dimLine?: string;
  subheading?: string;
  items: FeatureItem[];
  columns?: 2 | 3 | 4;
  cardStyle?: "plain" | "bordered" | "elevated";
}

const {
  eyebrow,
  heading,
  dimLine,
  subheading,
  items,
  columns = 3,
  cardStyle = "bordered",
} = Astro.props;

// Static maps so Tailwind discovers all utilities.
const columnClasses = {
  2: "grid grid-cols-1 sm:grid-cols-2 gap-6",
  3: "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6",
  4: "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6",
} as const;

const cardClasses = {
  plain: "p-0 bg-transparent",
  bordered:
    "p-7 md:p-9 rounded-2xl bg-white border border-[rgb(var(--color-border))] motion-safe:transition motion-safe:hover:-translate-y-1 hover:border-[rgb(var(--color-border-strong))]",
  elevated:
    "p-7 md:p-9 rounded-2xl bg-white border border-[rgb(var(--color-border))] shadow-sm motion-safe:transition motion-safe:hover:-translate-y-1 hover:shadow-lg",
} as const;
---

<div>
  {heading && (
    <SectionHeading
      eyebrow={eyebrow}
      heading={heading}
      dimLine={dimLine}
      subheading={subheading}
    />
  )}

  <ul class={columnClasses[columns]}>
    {items.map((item, i) => (
      <li
        class={`flex flex-col ${cardClasses[cardStyle]}`}
        data-reveal
        style={`--reveal-delay: ${i * 80}ms`}
      >
        {item.icon && (
          <span
            class="inline-flex items-center justify-center w-11 h-11 mb-6 rounded-xl bg-[rgb(var(--color-surface-alt))] text-[rgb(var(--color-accent))] text-xl font-bold"
            aria-hidden="true"
          >
            {item.icon}
          </span>
        )}
        <h3 class="mb-3 text-xl md:text-[1.375rem] font-bold tracking-[-0.015em] leading-snug text-[rgb(var(--color-text))]">
          {item.title}
        </h3>
        {item.meta && (
          <p class="mb-3 text-lg font-bold text-[rgb(var(--color-accent))]">{item.meta}</p>
        )}
        <p class="text-[1.0625rem] leading-[1.65] text-[rgb(var(--color-text))]/72">
          {item.description}
        </p>
      </li>
    ))}
  </ul>
</div>
