---
import Button from "@/components/ui/Button.astro";
import ImagePlaceholder from "@/components/ui/ImagePlaceholder.astro";

interface Props {
  heading: string;
  body: string;
  imagePath?: string | null;
  imageAlt?: string;
  imagePlaceholderLabel?: string;
  imageOnRight?: boolean;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  heading,
  body,
  imagePath = null,
  imageAlt = "",
  imagePlaceholderLabel,
  imageOnRight = true,
  ctaLabel,
  ctaHref,
} = Astro.props;

const textOrder = imageOnRight ? "lg:order-1" : "lg:order-2";
const visualOrder = imageOnRight ? "lg:order-2" : "lg:order-1";
---

<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
  <div class={textOrder} data-reveal>
    <h2 class="mb-5 text-3xl md:text-4xl lg:text-5xl font-bold leading-[1.08] tracking-tight text-balance">
      {heading}
    </h2>
    <p class="text-lg md:text-xl leading-[1.6] text-[rgb(var(--color-text))]/75 max-w-[54ch]">
      {body}
    </p>
    {ctaLabel && ctaHref && (
      <div class="mt-8">
        <Button href={ctaHref} variant="secondary">{ctaLabel}</Button>
      </div>
    )}
  </div>
  <div class={visualOrder} data-reveal style="--reveal-delay: 100ms">
    {imagePath ? (
      <img
        src={imagePath}
        alt={imageAlt}
        class="w-full rounded-2xl shadow-[0_18px_48px_rgb(0_0_0/0.10)]"
      />
    ) : (
      <ImagePlaceholder label={imagePlaceholderLabel} aspectRatio="4/3" />
    )}
  </div>
</div>
