---
import SectionHeading from "@/components/ui/SectionHeading.astro";
import Icon from "@/components/ui/Icon.astro";
import type { OpeningHours } from "@/data/business";

interface Props {
  phone?: string;
  email?: string;
  address?: string;
  mapsUrl?: string;
  facebookUrl?: string;
  openingHours?: OpeningHours[];
  compact?: boolean;
  heading?: string;
  dimLine?: string;
  eyebrow?: string;
  subheading?: string;
}

const {
  phone,
  email,
  address,
  mapsUrl,
  facebookUrl,
  openingHours,
  compact = false,
  heading,
  dimLine,
  eyebrow,
  subheading,
} = Astro.props;

const telHref = phone ? `tel:${phone.replace(/[^+\d]/g, "")}` : "";
const hasContactCards = Boolean(phone || email || address || facebookUrl);

const cardClasses =
  "flex flex-col gap-2 p-6 md:p-7 rounded-2xl bg-white border border-[rgb(var(--color-border))] transition-[border-color,transform] motion-safe:hover:-translate-y-0.5 hover:border-[rgb(var(--color-border-strong))]";
const iconBadge =
  "inline-flex items-center justify-center w-11 h-11 mb-2 rounded-xl bg-[rgb(var(--color-surface-alt))] text-[rgb(var(--color-accent))]";
const labelClasses =
  "text-[0.7rem] font-semibold uppercase tracking-[0.12em] text-[rgb(var(--color-muted))]";
const valueClasses =
  "text-xl font-bold leading-snug tracking-[-0.01em] text-[rgb(var(--color-accent))] hover:text-[rgb(var(--color-accent-dark))] hover:underline";

const layoutClasses = compact
  ? "grid grid-cols-1 gap-6"
  : "grid grid-cols-1 lg:grid-cols-[1.5fr_1fr] gap-6 lg:gap-10 items-start";

const cardsGridClasses = compact
  ? "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4"
  : "grid grid-cols-1 sm:grid-cols-2 gap-4";
---

<div class="max-w-[1040px] mx-auto">
  {heading && (
    <SectionHeading
      eyebrow={eyebrow}
      heading={heading}
      dimLine={dimLine}
      subheading={subheading}
    />
  )}

  <div class={layoutClasses}>
    {hasContactCards && (
      <ul class={cardsGridClasses}>
        {phone && (
          <li class={cardClasses} data-reveal style="--reveal-delay: 0ms">
            <span class={iconBadge}><Icon name="phone" size={20} strokeWidth={1.9} /></span>
            <span class={labelClasses}>Telefonas</span>
            <a class={valueClasses} href={telHref}>{phone}</a>
          </li>
        )}

        {email && (
          <li class={cardClasses} data-reveal style="--reveal-delay: 80ms">
            <span class={iconBadge}><Icon name="mail" size={20} strokeWidth={1.9} /></span>
            <span class={labelClasses}>El. paštas</span>
            <a class={valueClasses} href={`mailto:${email}`}>{email}</a>
          </li>
        )}

        {address && (
          <li class={cardClasses} data-reveal style="--reveal-delay: 160ms">
            <span class={iconBadge}><Icon name="map-pin" size={20} strokeWidth={1.9} /></span>
            <span class={labelClasses}>Adresas</span>
            {mapsUrl ? (
              <a
                class={valueClasses}
                href={mapsUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                {address}
              </a>
            ) : (
              <span class="text-xl font-bold leading-snug tracking-[-0.01em] text-[rgb(var(--color-text))]">
                {address}
              </span>
            )}
          </li>
        )}

        {facebookUrl && (
          <li class={cardClasses} data-reveal style="--reveal-delay: 240ms">
            <span class={iconBadge}><Icon name="facebook" size={20} strokeWidth={1.9} /></span>
            <span class={labelClasses}>Facebook</span>
            <a
              class={valueClasses}
              href={facebookUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              Sekti puslapį
            </a>
          </li>
        )}
      </ul>
    )}

    {!compact && openingHours && openingHours.length > 0 && (
      <div
        class="rounded-2xl bg-white border border-[rgb(var(--color-border))] p-6 md:p-7"
        data-reveal
        style="--reveal-delay: 100ms"
      >
        <h3 class="mb-5 pb-3 border-b border-[rgb(var(--color-border))] text-[0.7rem] font-semibold uppercase tracking-[0.12em] text-[rgb(var(--color-muted))]">
          Darbo laikas
        </h3>
        <dl class="grid gap-3">
          {openingHours.map((row) => (
            <div class="grid grid-cols-[1fr_auto] gap-4 text-[0.9375rem] leading-snug">
              <dt class="text-[rgb(var(--color-text))]/80">{row.day}</dt>
              <dd class="font-semibold text-[rgb(var(--color-text))]">{row.hours}</dd>
            </div>
          ))}
        </dl>
      </div>
    )}
  </div>
</div>
