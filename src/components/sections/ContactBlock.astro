---
import SectionHeading from "@/components/ui/SectionHeading.astro";
import type { OpeningHours } from "@/data/business";

interface Props {
  phone?: string;
  email?: string;
  address?: string;
  mapsUrl?: string;
  facebookUrl?: string;
  openingHours?: OpeningHours[];
  compact?: boolean;
  heading?: string;
  dimLine?: string;
  eyebrow?: string;
  subheading?: string;
}

const {
  phone,
  email,
  address,
  mapsUrl,
  facebookUrl,
  openingHours,
  compact = false,
  heading,
  dimLine,
  eyebrow,
  subheading,
} = Astro.props;

const telHref = phone ? `tel:${phone.replace(/[^+\d]/g, "")}` : "";
const hasContactCards = Boolean(phone || email || address || facebookUrl);

const cardClasses =
  "flex flex-col gap-1.5 p-5 md:p-6 rounded-2xl bg-white border border-[rgb(var(--color-border))] transition-colors hover:border-[rgb(var(--color-border-strong))]";
const iconClasses =
  "inline-flex items-center justify-center w-10 h-10 mb-1 rounded-full bg-[rgb(var(--color-surface-alt))] text-[rgb(var(--color-accent))] text-base font-bold leading-none";
const labelClasses =
  "text-xs font-semibold uppercase tracking-[0.05em] text-[rgb(var(--color-muted))]";
const valueClasses =
  "text-lg font-semibold leading-snug text-[rgb(var(--color-accent))] hover:underline";

const layoutClasses = compact
  ? "grid grid-cols-1 gap-6"
  : "grid grid-cols-1 lg:grid-cols-[1.5fr_1fr] gap-8 lg:gap-12 items-start";

const cardsGridClasses = compact
  ? "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4"
  : "grid grid-cols-1 sm:grid-cols-2 gap-4";
---

<div class="max-w-[1040px] mx-auto">
  {heading && (
    <SectionHeading
      eyebrow={eyebrow}
      heading={heading}
      dimLine={dimLine}
      subheading={subheading}
    />
  )}

  <div class={layoutClasses}>
    {hasContactCards && (
      <ul class={cardsGridClasses}>
        {phone && (
          <li class={cardClasses} data-reveal style="--reveal-delay: 0ms">
            <span class={iconClasses} aria-hidden="true">📞</span>
            <span class={labelClasses}>Telefonas</span>
            <a class={valueClasses} href={telHref}>{phone}</a>
          </li>
        )}

        {email && (
          <li class={cardClasses} data-reveal style="--reveal-delay: 80ms">
            <span class={iconClasses} aria-hidden="true">✉</span>
            <span class={labelClasses}>El. paštas</span>
            <a class={valueClasses} href={`mailto:${email}`}>{email}</a>
          </li>
        )}

        {address && (
          <li class={cardClasses} data-reveal style="--reveal-delay: 160ms">
            <span class={iconClasses} aria-hidden="true">📍</span>
            <span class={labelClasses}>Adresas</span>
            {mapsUrl ? (
              <a
                class={valueClasses}
                href={mapsUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                {address}
              </a>
            ) : (
              <span class="text-lg font-semibold leading-snug text-[rgb(var(--color-text))]">
                {address}
              </span>
            )}
          </li>
        )}

        {facebookUrl && (
          <li class={cardClasses} data-reveal style="--reveal-delay: 240ms">
            <span class={iconClasses} aria-hidden="true">f</span>
            <span class={labelClasses}>Facebook</span>
            <a
              class={valueClasses}
              href={facebookUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              Sekti puslapį
            </a>
          </li>
        )}
      </ul>
    )}

    {!compact && openingHours && openingHours.length > 0 && (
      <div
        class="rounded-2xl bg-white border border-[rgb(var(--color-border))] p-6"
        data-reveal
        style="--reveal-delay: 100ms"
      >
        <h3 class="mb-4 pb-3 border-b border-[rgb(var(--color-border))] text-base font-bold tracking-tight">
          Darbo laikas
        </h3>
        <dl class="grid gap-2.5">
          {openingHours.map((row) => (
            <div class="grid grid-cols-[1fr_auto] gap-4 text-base leading-snug">
              <dt class="text-[rgb(var(--color-text))]">{row.day}</dt>
              <dd class="font-semibold text-[rgb(var(--color-muted))]">{row.hours}</dd>
            </div>
          ))}
        </dl>
      </div>
    )}
  </div>
</div>
