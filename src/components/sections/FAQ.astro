---
import SectionHeading from "@/components/ui/SectionHeading.astro";
import type { FaqItem } from "@/data/pages/services";

interface Props {
  heading?: string;
  eyebrow?: string;
  dimLine?: string;
  subheading?: string;
  items: FaqItem[];
}

const { heading, eyebrow, dimLine, subheading, items } = Astro.props;
---

<div class="max-w-[800px] mx-auto">
  {heading && (
    <SectionHeading
      eyebrow={eyebrow}
      heading={heading}
      dimLine={dimLine}
      subheading={subheading}
    />
  )}

  <div class="flex flex-col gap-3">
    {items.map((item, i) => (
      <details
        class="group rounded-2xl bg-white border border-[rgb(var(--color-border))] overflow-hidden transition-colors open:border-[rgb(var(--color-border-strong))]"
        data-reveal
        style={`--reveal-delay: ${i * 70}ms`}
      >
        <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none [&::-webkit-details-marker]:hidden text-lg font-semibold leading-snug text-[rgb(var(--color-text))]">
          <span>{item.question}</span>
          <span
            class="relative inline-block w-3.5 h-3.5 shrink-0 before:content-[''] before:absolute before:top-1/2 before:left-0 before:w-full before:h-0.5 before:-translate-y-1/2 before:bg-[rgb(var(--color-accent))] before:rounded-sm after:content-[''] after:absolute after:left-1/2 after:top-0 after:h-full after:w-0.5 after:-translate-x-1/2 after:bg-[rgb(var(--color-accent))] after:rounded-sm after:transition-transform group-open:after:scale-y-0"
            aria-hidden="true"
          ></span>
        </summary>
        <div class="px-6 pb-6 text-[1.0625rem] leading-[1.65] text-[rgb(var(--color-text))]/72">
          <p>{item.answer}</p>
        </div>
      </details>
    ))}
  </div>
</div>
