---
import Button from "@/components/ui/Button.astro";
import ImagePlaceholder from "@/components/ui/ImagePlaceholder.astro";
import type { Cta } from "@/data/business";
import type { TrustPoint } from "@/data/pages/home";

interface Props {
  eyebrow?: string;
  headline: string;
  subheadline: string;
  primaryCta: Cta;
  phone?: string;
  phoneLabel?: string;
  trustPoints?: TrustPoint[];
  imagePath?: string | null;
  imageAlt?: string;
  imagePlaceholderLabel?: string;
}

const {
  eyebrow,
  headline,
  subheadline,
  primaryCta,
  phone,
  phoneLabel = "arba skambinkite",
  trustPoints,
  imagePath = null,
  imageAlt = "",
  imagePlaceholderLabel,
} = Astro.props;

const telHref = phone ? `tel:${phone.replace(/[^+\d]/g, "")}` : "";
---

<section class="bg-[rgb(var(--color-bg))] py-16 md:py-24 lg:py-28">
  <div class="mx-auto w-full max-w-[1180px] px-5 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-[1.05fr_1fr] gap-12 lg:gap-20 items-center">
      <div data-reveal>
        {eyebrow && (
          <span class="inline-block mb-5 text-xs font-bold uppercase tracking-[0.18em] text-[rgb(var(--color-accent))]">
            {eyebrow}
          </span>
        )}
        <h1 class="mb-5 text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.04] tracking-[-0.03em] text-balance max-w-[18ch]">
          {headline}
        </h1>
        <p class="mb-10 text-lg leading-relaxed text-[rgb(var(--color-muted))] max-w-[52ch]">
          {subheadline}
        </p>

        <div class="flex flex-wrap items-center gap-4 sm:gap-10">
          <Button href={primaryCta.href} variant="primary" size="lg">
            {primaryCta.label}
          </Button>
          {phone && (
            <a
              href={telHref}
              class="inline-flex flex-col gap-1 leading-tight text-[rgb(var(--color-text))] hover:no-underline sm:pl-6 sm:border-l sm:border-[rgb(var(--color-border))]"
            >
              <span class="text-xs font-semibold uppercase tracking-[0.06em] text-[rgb(var(--color-muted))]">
                {phoneLabel}
              </span>
              <span class="text-lg font-bold text-[rgb(var(--color-accent))]">{phone}</span>
            </a>
          )}
        </div>

        {trustPoints && trustPoints.length > 0 && (
          <ul class="mt-12 pt-8 border-t border-[rgb(var(--color-border))] flex flex-wrap gap-x-8 gap-y-3">
            {trustPoints.map((p, i) => (
              <li
                class="inline-flex items-center gap-2 text-base font-medium leading-snug"
                data-reveal
                style={`--reveal-delay: ${250 + i * 80}ms`}
              >
                {p.icon && (
                  <span class="text-[rgb(var(--color-accent))] font-bold text-lg leading-none" aria-hidden="true">
                    {p.icon}
                  </span>
                )}
                <span>{p.text}</span>
              </li>
            ))}
          </ul>
        )}
      </div>

      <div class="w-full" data-reveal style="--reveal-delay: 120ms">
        {imagePath ? (
          <img
            src={imagePath}
            alt={imageAlt}
            class="w-full h-auto rounded-2xl shadow-[0_18px_48px_rgb(0_0_0/0.10)]"
          />
        ) : (
          <ImagePlaceholder label={imagePlaceholderLabel} aspectRatio="5/4" />
        )}
      </div>
    </div>
  </div>
</section>
