---
import Button from "@/components/ui/Button.astro";
import ImagePlaceholder from "@/components/ui/ImagePlaceholder.astro";
import type { Cta } from "@/data/business";
import type { TrustPoint } from "@/data/pages/home";

interface Props {
  eyebrow?: string;
  headline: string;
  subheadline: string;
  primaryCta: Cta;
  phone?: string;
  phoneLabel?: string;
  trustPoints?: TrustPoint[];
  imagePath?: string | null;
  imageAlt?: string;
  imagePlaceholderLabel?: string;
}

const {
  eyebrow,
  headline,
  subheadline,
  primaryCta,
  phone,
  phoneLabel = "arba skambinkite",
  trustPoints,
  imagePath = null,
  imageAlt = "",
  imagePlaceholderLabel,
} = Astro.props;

const telHref = phone ? `tel:${phone.replace(/[^+\d]/g, "")}` : "";
---

<section class="hero-section">
  <div class="hero-section__container">
    <div class="hero">
      <div class="hero__content" data-reveal>
        {eyebrow && <span class="hero__eyebrow">{eyebrow}</span>}
        <h1 class="hero__headline">{headline}</h1>
        <p class="hero__sub">{subheadline}</p>

        <div class="hero__actions">
          <Button href={primaryCta.href} variant="primary">
            {primaryCta.label}
          </Button>
          {phone && (
            <a href={telHref} class="hero__phone">
              <span class="hero__phone-label">{phoneLabel}</span>
              <span class="hero__phone-number">{phone}</span>
            </a>
          )}
        </div>

        {trustPoints && trustPoints.length > 0 && (
          <ul class="hero__trust">
            {trustPoints.map((p, i) => (
              <li data-reveal style={`--reveal-delay: ${250 + i * 80}ms`}>
                {p.icon && <span class="hero__trust-icon" aria-hidden="true">{p.icon}</span>}
                <span>{p.text}</span>
              </li>
            ))}
          </ul>
        )}
      </div>

      <div class="hero__visual" data-reveal="scale" style="--reveal-delay: 120ms">
        {imagePath ? (
          <img src={imagePath} alt={imageAlt} class="hero__image" />
        ) : (
          <ImagePlaceholder
            label={imagePlaceholderLabel}
            aspectRatio="5/4"
          />
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    padding-block: clamp(3.5rem, 8vw, 6.5rem);
    background-color: var(--color-bg);
  }
  .hero-section__container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--spacing-lg);
    width: 100%;
  }
  @media (min-width: 768px) {
    .hero-section__container {
      padding-inline: var(--spacing-2xl);
    }
  }

  .hero {
    display: grid;
    gap: var(--spacing-2xl);
    grid-template-columns: 1fr;
    align-items: center;
  }
  @media (min-width: 900px) {
    .hero {
      grid-template-columns: 1.05fr 1fr;
      gap: clamp(var(--spacing-2xl), 6vw, 5rem);
    }
  }

  .hero__eyebrow {
    display: inline-block;
    font-size: var(--font-size-xs);
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    margin-bottom: var(--spacing-lg);
  }

  .hero__headline {
    font-size: clamp(2.5rem, 5.5vw, var(--font-size-5xl));
    line-height: var(--line-height-tight);
    margin-bottom: var(--spacing-lg);
    max-width: 18ch;
    letter-spacing: var(--tracking-display);
    font-weight: 600;
    text-wrap: balance;
  }

  .hero__sub {
    font-size: var(--font-size-md);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--spacing-2xl);
    max-width: 52ch;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-md) var(--spacing-2xl);
  }
  .hero__actions::before {
    content: none;
  }
  @media (min-width: 480px) {
    .hero__phone {
      padding-left: var(--spacing-lg);
      border-left: 1px solid var(--color-border);
    }
  }

  .hero__phone {
    display: inline-flex;
    flex-direction: column;
    line-height: 1.2;
    color: var(--color-text);
    gap: 4px;
    transition: color var(--motion-duration-fast) var(--motion-ease);
  }
  .hero__phone:hover { text-decoration: none; }
  .hero__phone:hover .hero__phone-number {
    text-decoration: underline;
  }
  .hero__phone-label {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }
  .hero__phone-number {
    font-weight: 700;
    font-size: var(--font-size-md);
    color: var(--color-primary);
  }

  .hero__trust {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-md) var(--spacing-xl);
    margin-top: var(--spacing-2xl);
    padding-top: var(--spacing-xl);
    border-top: 1px solid var(--color-border);
  }
  .hero__trust li {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-size: var(--font-size-base);
    color: var(--color-text);
    font-weight: 500;
    line-height: 1.4;
  }
  .hero__trust-icon {
    color: var(--color-primary);
    font-weight: 700;
    font-size: var(--font-size-md);
    line-height: 1;
  }

  .hero__visual {
    width: 100%;
  }
  .hero__image {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }
</style>
