---
import Button from "@/components/ui/Button.astro";
import type { Cta } from "@/data/business";

interface Props {
  heading: string;
  subtext?: string;
  primaryCta: Cta;
  /**
   * Default is "dark" — premium conversion section with subtle radial
   * gradient. Use "alt" or "default" for softer placements.
   */
  bg?: "default" | "alt" | "dark" | "primary";
  dimLine?: string;
  eyebrow?: string;
}

const {
  heading,
  subtext,
  primaryCta,
  bg = "dark",
  dimLine,
  eyebrow,
} = Astro.props;

const wrapperClasses = {
  default: "bg-[rgb(var(--color-bg))] text-[rgb(var(--color-text))]",
  alt: "bg-[rgb(var(--color-surface-alt))] text-[rgb(var(--color-text))]",
  dark: "bg-[rgb(var(--color-dark))] text-white",
  primary: "bg-[rgb(var(--color-accent))] text-white",
} as const;

const eyebrowClasses = {
  default: "text-[rgb(var(--color-accent))]",
  alt: "text-[rgb(var(--color-accent))]",
  dark: "text-white/85",
  primary: "text-white/85",
} as const;

const subClasses = {
  default: "text-[rgb(var(--color-muted))]",
  alt: "text-[rgb(var(--color-muted))]",
  dark: "text-white/70",
  primary: "text-white/80",
} as const;

const dimClasses = {
  default: "text-[rgb(var(--color-text))]/40",
  alt: "text-[rgb(var(--color-text))]/40",
  dark: "text-white/35",
  primary: "text-white/40",
} as const;

// Subtle radial glow only on dark variant.
const darkBgStyle =
  bg === "dark"
    ? "background-image: radial-gradient(circle at 50% 0%, rgb(255 255 255 / 0.08) 0%, rgb(255 255 255 / 0) 55%), radial-gradient(circle at 80% 100%, rgb(var(--color-dark-soft) / 0.7) 0%, rgb(var(--color-dark-soft) / 0) 60%);"
    : undefined;
---

<section
  class={`relative overflow-hidden py-20 md:py-28 ${wrapperClasses[bg]}`}
  style={darkBgStyle}
>
  <div class="relative mx-auto w-full max-w-[1180px] px-5 sm:px-6 lg:px-8">
    <div class="max-w-[720px] mx-auto text-center" data-reveal>
      {eyebrow && (
        <span class={`inline-block mb-4 text-xs font-bold uppercase tracking-[0.18em] ${eyebrowClasses[bg]}`}>
          {eyebrow}
        </span>
      )}
      <h2 class="mb-5 text-4xl md:text-5xl lg:text-6xl font-bold leading-[1.05] tracking-tight text-balance">
        <span>{heading}</span>
        {dimLine && (
          <>
            {" "}
            <span class={dimClasses[bg]}>{dimLine}</span>
          </>
        )}
      </h2>
      {subtext && (
        <p class={`mb-10 text-lg leading-relaxed max-w-[56ch] mx-auto ${subClasses[bg]}`}>
          {subtext}
        </p>
      )}
      <div class="flex justify-center">
        <Button href={primaryCta.href} variant="primary" size="lg">
          {primaryCta.label}
        </Button>
      </div>
    </div>
  </div>
</section>
