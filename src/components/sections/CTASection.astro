---
import Button from "@/components/ui/Button.astro";
import type { Cta } from "@/data/business";

interface Props {
  heading: string;
  subtext?: string;
  primaryCta: Cta;
  /**
   * Default is "dark" — premium conversion section with subtle radial
   * gradient. Use "alt" or "default" for softer placements.
   */
  bg?: "default" | "alt" | "dark" | "primary";
  dimLine?: string;
  eyebrow?: string;
}

const { heading, subtext, primaryCta, bg = "dark", dimLine, eyebrow } =
  Astro.props;
---

<section class={`cta-section-wrap cta-section-wrap--${bg}`}>
  <div class="cta-section-wrap__container">
    <div class="cta-section" data-reveal>
      {eyebrow && <span class="cta-section__eyebrow">{eyebrow}</span>}
      <h2 class="cta-section__heading">
        <span>{heading}</span>
        {dimLine && (
          <>
            {" "}
            <span class="cta-section__heading-dim">{dimLine}</span>
          </>
        )}
      </h2>
      {subtext && <p class="cta-section__sub">{subtext}</p>}
      <div class="cta-section__action">
        <Button href={primaryCta.href} variant="primary" size="lg">
          {primaryCta.label}
        </Button>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section-wrap {
    padding-block: var(--section-padding-y);
    position: relative;
    overflow: hidden;
  }
  .cta-section-wrap--default { background-color: var(--color-bg); }
  .cta-section-wrap--alt { background-color: var(--color-bg-alt); }
  .cta-section-wrap--dark {
    background-color: var(--color-bg-dark);
    color: var(--color-text-inverse);
    background-image: radial-gradient(
      circle at 50% 0%,
      rgba(255, 255, 255, 0.10) 0%,
      rgba(255, 255, 255, 0) 55%
    );
  }
  .cta-section-wrap--primary {
    background-color: var(--color-primary);
    color: var(--color-primary-contrast);
  }

  .cta-section-wrap__container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--spacing-lg);
    width: 100%;
    position: relative;
  }
  @media (min-width: 768px) {
    .cta-section-wrap__container {
      padding-inline: var(--spacing-2xl);
    }
  }

  .cta-section {
    text-align: center;
    max-width: 720px;
    margin-inline: auto;
  }

  .cta-section__eyebrow {
    display: inline-block;
    font-size: var(--font-size-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--color-primary);
    margin-bottom: var(--spacing-md);
  }
  .cta-section-wrap--dark .cta-section__eyebrow,
  .cta-section-wrap--primary .cta-section__eyebrow {
    color: rgba(255, 255, 255, 0.85);
  }

  .cta-section__heading {
    font-size: clamp(2rem, 4.4vw, var(--font-size-4xl));
    line-height: var(--line-height-tight);
    letter-spacing: var(--tracking-tighter);
    font-weight: 600;
    color: inherit;
    margin-bottom: var(--spacing-md);
    text-wrap: balance;
  }
  .cta-section-wrap--dark .cta-section__heading,
  .cta-section-wrap--primary .cta-section__heading {
    color: var(--color-text-inverse);
  }
  .cta-section__heading-dim {
    color: var(--color-text-dim);
  }
  .cta-section-wrap--dark .cta-section__heading-dim,
  .cta-section-wrap--primary .cta-section__heading-dim {
    color: var(--color-text-dim-on-dark);
  }

  .cta-section__sub {
    font-size: var(--font-size-md);
    margin-bottom: var(--spacing-2xl);
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: 56ch;
    margin-inline: auto;
  }
  .cta-section-wrap--dark .cta-section__sub,
  .cta-section-wrap--primary .cta-section__sub {
    color: rgba(255, 255, 255, 0.7);
  }

  .cta-section__action {
    display: flex;
    justify-content: center;
  }
</style>
