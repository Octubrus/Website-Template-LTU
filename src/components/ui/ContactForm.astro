---
import Button from "./Button.astro";

interface Props {
  demoMode: boolean;
  contactFormEnabled: boolean;
  heading?: string;
  subtext?: string;
  demoNotice: string;
  successMessage: string;
}

const {
  demoMode,
  contactFormEnabled,
  heading,
  subtext,
  demoNotice,
  successMessage,
} = Astro.props;
---

{contactFormEnabled && (
  <div class="contact-form-wrap" data-reveal>
    {(heading || subtext) && (
      <header class="contact-form-wrap__head">
        {heading && <h2 class="contact-form-wrap__heading">{heading}</h2>}
        {subtext && <p class="contact-form-wrap__sub">{subtext}</p>}
      </header>
    )}

    {demoMode && (
      <p class="contact-form-wrap__demo-notice" role="note">
        <span class="contact-form-wrap__demo-tag">Demo</span>
        {demoNotice}
      </p>
    )}

    <form class="contact-form" novalidate data-success={successMessage}>
      <div class="contact-form__row">
        <label class="contact-form__field">
          <span class="contact-form__label">Vardas</span>
          <input type="text" name="name" required autocomplete="name" />
        </label>
        <label class="contact-form__field">
          <span class="contact-form__label">Telefono numeris</span>
          <input type="tel" name="phone" required autocomplete="tel" />
        </label>
      </div>

      <label class="contact-form__field">
        <span class="contact-form__label">El. paštas</span>
        <input type="email" name="email" required autocomplete="email" />
      </label>

      <label class="contact-form__field">
        <span class="contact-form__label">Žinutė</span>
        <textarea name="message" rows="5" required></textarea>
      </label>

      <div class="contact-form__actions">
        <Button type="submit" variant="primary" size="lg">
          Siųsti žinutę
        </Button>
      </div>

      <p class="contact-form__success" hidden role="status" aria-live="polite"></p>
    </form>
  </div>
)}

<script>
  document.querySelectorAll<HTMLFormElement>(".contact-form").forEach((form) => {
    const successEl = form.querySelector<HTMLParagraphElement>(".contact-form__success");
    const successText = form.dataset.success ?? "Ačiū! Žinutę gavome.";

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      form.reset();
      if (successEl) {
        successEl.textContent = successText;
        successEl.hidden = false;
      }
    });
  });
</script>

<style>
  .contact-form-wrap {
    max-width: 640px;
    margin-inline: auto;
  }
  .contact-form-wrap__head {
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }
  .contact-form-wrap__heading {
    margin-bottom: var(--spacing-sm);
  }
  .contact-form-wrap__sub {
    color: var(--color-text-muted);
  }
  .contact-form-wrap__demo-notice {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    background-color: var(--color-info-bg);
    border: 1px solid var(--color-info-border);
    color: var(--color-text);
    padding: var(--spacing-md) var(--spacing-lg);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-snug);
    margin-bottom: var(--spacing-lg);
  }
  .contact-form-wrap__demo-tag {
    background-color: var(--color-primary);
    color: var(--color-primary-contrast);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: var(--radius-pill);
    flex-shrink: 0;
  }

  .contact-form {
    display: grid;
    gap: var(--spacing-md);
  }
  .contact-form__row {
    display: grid;
    gap: var(--spacing-md);
  }
  @media (min-width: 600px) {
    .contact-form__row {
      grid-template-columns: 1fr 1fr;
    }
  }
  .contact-form__field {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }
  .contact-form__label {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-text);
  }
  .contact-form input,
  .contact-form textarea {
    font: inherit;
    font-size: var(--font-size-base);
    color: var(--color-text);
    background-color: var(--color-white);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-md);
    padding: 0.7rem 0.9rem;
    width: 100%;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(45, 125, 154, 0.15);
  }
  .contact-form textarea {
    resize: vertical;
    min-height: 120px;
  }
  .contact-form__actions {
    margin-top: var(--spacing-md);
    display: flex;
    justify-content: flex-start;
  }
  .contact-form__actions :global(.btn) {
    width: 100%;
  }
  @media (min-width: 600px) {
    .contact-form__actions :global(.btn) {
      width: auto;
      min-width: 220px;
    }
  }
  .contact-form__success {
    background-color: var(--color-success-bg);
    color: var(--color-success);
    padding: var(--spacing-md);
    border-radius: var(--radius-md);
    font-weight: 500;
    text-align: center;
  }
</style>
