---
import Button from "./Button.astro";

interface Props {
  demoMode: boolean;
  contactFormEnabled: boolean;
  heading?: string;
  subtext?: string;
  demoNotice: string;
  successMessage: string;
}

const {
  demoMode,
  contactFormEnabled,
  heading,
  subtext,
  demoNotice,
  successMessage,
} = Astro.props;

const inputClasses =
  "w-full rounded-xl border border-[rgb(var(--color-border-strong))] bg-white px-4 py-3 text-base text-[rgb(var(--color-text))] transition-[border-color,box-shadow] duration-150 focus:outline-none focus:border-[rgb(var(--color-accent))] focus:ring-4 focus:ring-[rgb(var(--color-accent))]/15";
---

{contactFormEnabled && (
  <div class="max-w-[640px] mx-auto" data-reveal>
    {(heading || subtext) && (
      <header class="mb-8 text-center">
        {heading && (
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-2">{heading}</h2>
        )}
        {subtext && <p class="text-[rgb(var(--color-muted))]">{subtext}</p>}
      </header>
    )}

    {demoMode && (
      <p
        class="flex items-center gap-3 mb-6 px-5 py-4 rounded-xl text-sm leading-snug bg-[rgb(var(--color-surface-alt))] border border-[rgb(var(--color-border))] text-[rgb(var(--color-text))]"
        role="note"
      >
        <span class="shrink-0 inline-block px-2 py-0.5 rounded-full bg-[rgb(var(--color-accent))] text-white text-[0.7rem] font-bold uppercase tracking-[0.06em]">
          Demo
        </span>
        <span>{demoNotice}</span>
      </p>
    )}

    <form class="contact-form grid gap-4" novalidate data-success={successMessage}>
      <div class="grid gap-4 sm:grid-cols-2">
        <label class="flex flex-col gap-1.5">
          <span class="text-sm font-semibold text-[rgb(var(--color-text))]">Vardas</span>
          <input type="text" name="name" required autocomplete="name" class={inputClasses} />
        </label>
        <label class="flex flex-col gap-1.5">
          <span class="text-sm font-semibold text-[rgb(var(--color-text))]">Telefono numeris</span>
          <input type="tel" name="phone" required autocomplete="tel" class={inputClasses} />
        </label>
      </div>

      <label class="flex flex-col gap-1.5">
        <span class="text-sm font-semibold text-[rgb(var(--color-text))]">El. paštas</span>
        <input type="email" name="email" required autocomplete="email" class={inputClasses} />
      </label>

      <label class="flex flex-col gap-1.5">
        <span class="text-sm font-semibold text-[rgb(var(--color-text))]">Žinutė</span>
        <textarea name="message" rows="5" required class={`${inputClasses} resize-y min-h-[120px]`}></textarea>
      </label>

      <div class="mt-2 flex justify-start">
        <Button type="submit" variant="primary" size="lg" class="w-full sm:w-auto sm:min-w-[220px]">
          Siųsti žinutę
        </Button>
      </div>

      <p
        class="contact-form__success hidden mt-2 px-4 py-3 rounded-xl text-center font-medium bg-emerald-50 text-emerald-700 border border-emerald-200"
        role="status"
        aria-live="polite"
      ></p>
    </form>
  </div>
)}

<script>
  document.querySelectorAll<HTMLFormElement>(".contact-form").forEach((form) => {
    const successEl = form.querySelector<HTMLParagraphElement>(".contact-form__success");
    const successText = form.dataset.success ?? "Ačiū! Žinutę gavome.";

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      form.reset();
      if (successEl) {
        successEl.textContent = successText;
        successEl.classList.remove("hidden");
      }
    });
  });
</script>
