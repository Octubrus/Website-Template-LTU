---
interface Props {
  businessName: string;
  logoPath: string | null;
  logoAlt: string;
  href?: string;
  size?: "sm" | "md" | "lg";
  class?: string;
}

const {
  businessName,
  logoPath,
  logoAlt,
  href = "/",
  size = "md",
  class: className = "",
} = Astro.props;

const altText =
  logoAlt && logoAlt.trim().length > 0 ? logoAlt : `${businessName} logotipas`;

const imgSizes = {
  sm: "h-7",
  md: "h-9",
  lg: "h-12",
} as const;

const textSizes = {
  sm: "text-base",
  md: "text-lg",
  lg: "text-xl",
} as const;
---

<a
  href={href}
  class={`inline-flex items-center text-[rgb(var(--color-text))] no-underline hover:no-underline ${className}`}
  aria-label={`${businessName} — pradžios puslapis`}
>
  {logoPath ? (
    <img src={logoPath} alt={altText} class={`block w-auto ${imgSizes[size]}`} />
  ) : (
    <span
      class={`font-bold tracking-tight text-[rgb(var(--color-text))] ${textSizes[size]}`}
    >
      {businessName}
    </span>
  )}
</a>
