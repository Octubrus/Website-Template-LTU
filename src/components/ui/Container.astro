---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div class={`container ${className}`}>
  <slot />
</div>

<style>
  .container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--spacing-lg);
    width: 100%;
  }
  @media (min-width: 768px) {
    .container { padding-inline: var(--spacing-2xl); }
  }
</style>
