---
import Container from "./Container.astro";

interface Props {
  id?: string;
  class?: string;
  bg?: "default" | "alt" | "dark" | "primary";
  spacing?: "sm" | "md" | "lg";
  contained?: boolean;
}

const {
  id,
  class: className = "",
  bg = "default",
  spacing = "md",
  contained = true,
} = Astro.props;

const bgClasses = {
  default: "bg-[rgb(var(--color-bg))] text-[rgb(var(--color-text))]",
  alt: "bg-[rgb(var(--color-surface-alt))] text-[rgb(var(--color-text))]",
  dark: "bg-[rgb(var(--color-dark))] text-white",
  primary: "bg-[rgb(var(--color-accent))] text-white",
} as const;

const spacingClasses = {
  sm: "py-14 md:py-20",
  md: "py-20 md:py-28",
  lg: "py-24 md:py-36",
} as const;

const classes = `${bgClasses[bg]} ${spacingClasses[spacing]} ${className}`.trim();

// Subtle radial glow for dark sections — adds premium depth without animation.
const darkBgStyle =
  bg === "dark"
    ? "background-image: radial-gradient(ellipse at 20% 0%, rgb(var(--color-dark-soft)) 0%, transparent 60%), radial-gradient(ellipse at 80% 100%, rgb(var(--color-dark-soft) / 0.6) 0%, transparent 55%);"
    : undefined;
---

<section id={id} class={classes} style={darkBgStyle}>
  {contained ? (
    <Container>
      <slot />
    </Container>
  ) : (
    <slot />
  )}
</section>
