---
import Section from "./Section.astro";

interface Props {
  eyebrow?: string;
  heading: string;
  dimLine?: string;
  subheading?: string;
}

const { eyebrow, heading, dimLine, subheading } = Astro.props;
---

<Section bg="alt" spacing="md">
  <div class="max-w-[800px] mx-auto text-center" data-reveal>
    {eyebrow && (
      <span class="inline-block mb-4 text-xs font-bold uppercase tracking-[0.18em] text-[rgb(var(--color-accent))]">
        {eyebrow}
      </span>
    )}
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold leading-[1.05] tracking-tight text-balance">
      <span>{heading}</span>
      {dimLine && (
        <>
          {" "}
          <span class="text-[rgb(var(--color-text))]/55">{dimLine}</span>
        </>
      )}
    </h1>
    {subheading && (
      <p class="mt-5 text-lg md:text-xl leading-[1.55] text-[rgb(var(--color-text))]/72 max-w-[60ch] mx-auto">
        {subheading}
      </p>
    )}
  </div>
</Section>
