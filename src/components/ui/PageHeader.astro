---
import Section from "./Section.astro";

interface Props {
  eyebrow?: string;
  heading: string;
  dimLine?: string;
  subheading?: string;
}

const { eyebrow, heading, dimLine, subheading } = Astro.props;
---

<Section bg="alt">
  <div class="page-header" data-reveal>
    {eyebrow && <span class="page-header__eyebrow">{eyebrow}</span>}
    <h1 class="page-header__heading">
      <span>{heading}</span>
      {dimLine && (
        <>
          {" "}
          <span class="page-header__heading-dim">{dimLine}</span>
        </>
      )}
    </h1>
    {subheading && <p class="page-header__sub">{subheading}</p>}
  </div>
</Section>

<style>
  .page-header {
    text-align: center;
    max-width: 800px;
    margin-inline: auto;
  }
  .page-header__eyebrow {
    display: inline-block;
    font-size: var(--font-size-xs);
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    margin-bottom: var(--spacing-md);
  }
  .page-header__heading {
    font-size: clamp(2.25rem, 4.8vw, var(--font-size-4xl));
    line-height: var(--line-height-tight);
    letter-spacing: var(--tracking-tighter);
    font-weight: 600;
    margin-bottom: var(--spacing-md);
    text-wrap: balance;
  }
  .page-header__heading-dim {
    color: var(--color-text-dim);
  }
  .page-header__sub {
    font-size: var(--font-size-md);
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: 60ch;
    margin-inline: auto;
  }
</style>
