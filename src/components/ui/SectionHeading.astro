---
interface Props {
  eyebrow?: string;
  heading: string;
  /**
   * Optional second heading line at the same size, rendered with reduced
   * opacity (~40%). Use selectively, not in every section.
   */
  dimLine?: string;
  subheading?: string;
  align?: "center" | "start";
  tone?: "default" | "inverse";
  class?: string;
}

const {
  eyebrow,
  heading,
  dimLine,
  subheading,
  align = "center",
  tone = "default",
  class: className = "",
} = Astro.props;

const alignClasses =
  align === "center"
    ? "max-w-[760px] mx-auto text-center"
    : "max-w-[760px] text-left";

const eyebrowColor =
  tone === "inverse"
    ? "text-white/85"
    : "text-[rgb(var(--color-accent))]";

const titleColor = tone === "inverse" ? "text-white" : "text-[rgb(var(--color-text))]";
const subColor =
  tone === "inverse" ? "text-white/70" : "text-[rgb(var(--color-muted))]";
const dimColor = tone === "inverse" ? "text-white/35" : "text-[rgb(var(--color-text))]/40";
---

<header class={`mb-12 md:mb-16 ${alignClasses} ${className}`} data-reveal>
  {eyebrow && (
    <span
      class={`inline-block mb-4 text-xs font-bold uppercase tracking-[0.18em] ${eyebrowColor}`}
    >
      {eyebrow}
    </span>
  )}
  <h2
    class={`text-4xl sm:text-5xl lg:text-6xl font-bold leading-[1.05] tracking-tight text-balance ${titleColor}`}
  >
    <span>{heading}</span>
    {dimLine && (
      <>
        {" "}
        <span class={dimColor}>{dimLine}</span>
      </>
    )}
  </h2>
  {subheading && (
    <p
      class={`mt-5 text-lg leading-relaxed max-w-[60ch] ${subColor} ${align === "center" ? "mx-auto" : ""}`}
    >
      {subheading}
    </p>
  )}
</header>
