---
interface Props {
  variant?: "primary" | "secondary" | "outline" | "ghost";
  size?: "md" | "lg";
  href?: string;
  type?: "button" | "submit" | "reset";
  class?: string;
  ariaLabel?: string;
}

const {
  variant = "primary",
  size = "md",
  href,
  type = "button",
  class: className = "",
  ariaLabel,
} = Astro.props;

// Static class maps so Tailwind can discover every utility at build time.
const base =
  "inline-flex items-center justify-center gap-2 font-semibold leading-tight rounded-xl border border-transparent whitespace-nowrap select-none transition-[background-color,color,border-color,transform,box-shadow] duration-200 ease-[cubic-bezier(0.22,0.61,0.36,1)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-[rgb(var(--color-accent))] focus-visible:ring-offset-[rgb(var(--color-bg))] active:scale-[0.99]";

const sizes = {
  md: "min-h-[50px] px-7 py-3 text-base",
  lg: "min-h-[54px] px-7 py-3.5 text-[1.0625rem]",
} as const;

const variants = {
  primary:
    "bg-[rgb(var(--color-accent))] text-white hover:bg-[rgb(var(--color-accent-dark))] motion-safe:hover:-translate-y-px hover:shadow-[0_10px_24px_rgb(var(--color-accent)/0.22)]",
  secondary:
    "bg-transparent text-[rgb(var(--color-accent))] border-[rgb(var(--color-accent))] hover:bg-[rgb(var(--color-accent))] hover:text-white",
  outline:
    "bg-transparent text-[rgb(var(--color-text))] border-[rgb(var(--color-border-strong))] hover:border-[rgb(var(--color-text))]",
  ghost:
    "bg-transparent text-[rgb(var(--color-text))] hover:bg-[rgb(var(--color-surface-alt))]",
} as const;

const classes = `${base} ${sizes[size]} ${variants[variant]} ${className}`.trim();
const isLink = typeof href === "string" && href.length > 0;
---

{isLink ? (
  <a href={href} class={classes} aria-label={ariaLabel}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} aria-label={ariaLabel}>
    <slot />
  </button>
)}
