---
interface Props {
  label?: string;
  aspectRatio?: string;
  class?: string;
}

const {
  label = "Įkelkite realią verslo, komandos arba patalpų nuotrauką.",
  aspectRatio = "4/3",
  class: className = "",
} = Astro.props;
---

<div
  class={`relative w-full overflow-hidden rounded-2xl border border-[rgb(var(--color-border))] bg-gradient-to-br from-[rgb(var(--color-surface-alt))] to-[rgb(var(--color-bg))] flex items-center justify-center px-6 py-12 ${className}`}
  style={`aspect-ratio: ${aspectRatio};`}
  role="img"
  aria-label={label}
>
  <div
    class="absolute inset-3 rounded-[14px] border border-dashed border-[rgb(var(--color-border-strong))] opacity-60 pointer-events-none"
    aria-hidden="true"
  ></div>
  <div class="relative max-w-[360px] text-center text-[rgb(var(--color-muted))]">
    <span class="block mb-1 font-semibold text-[rgb(var(--color-text))]">
      Nuotraukos vieta
    </span>
    <span class="block text-sm leading-snug">{label}</span>
  </div>
</div>
