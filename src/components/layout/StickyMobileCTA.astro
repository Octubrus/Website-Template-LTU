---
import Icon from "@/components/ui/Icon.astro";

interface Props {
  href: string;
  label: string;
  secondaryLabel?: string;
}

const { href, label, secondaryLabel } = Astro.props;
---

{href && (
  <a
    href={href}
    class="sticky-cta fixed bottom-0 left-0 right-0 z-[800] flex md:hidden items-center justify-center gap-2.5 px-4 bg-[rgb(var(--color-accent))] text-white font-semibold no-underline shadow-[0_-4px_16px_rgb(0_0_0/0.1)] transition-[opacity,visibility,background-color] duration-200 hover:bg-[rgb(var(--color-accent-dark))]"
    style="height: var(--mobile-cta-height, 56px);"
    aria-label={secondaryLabel ? `${label} - ${secondaryLabel}` : label}
  >
    <Icon name="phone" size={18} strokeWidth={1.9} />
    <span class="text-[0.9375rem]">{label}</span>
    {secondaryLabel && (
      <span class="text-[0.875rem] opacity-90">{secondaryLabel}</span>
    )}
  </a>
)}

<style>
  /* Provide --mobile-cta-height for DemoWidget's bottom offset. */
  :global(:root) {
    --mobile-cta-height: 56px;
  }
  /* Reserve bottom space on mobile so content isn't hidden under the CTA. */
  @media (max-width: 767px) {
    :global(body) {
      padding-bottom: var(--mobile-cta-height);
    }
  }
</style>
