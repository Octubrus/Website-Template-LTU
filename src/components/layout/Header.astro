---
import Logo from "@/components/ui/Logo.astro";
import Button from "@/components/ui/Button.astro";
import Container from "@/components/ui/Container.astro";
import Icon from "@/components/ui/Icon.astro";
import type { NavItem } from "@/data/navigation";
import type { Cta } from "@/data/business";

interface Props {
  businessName: string;
  logoPath: string | null;
  logoAlt: string;
  phone: string;
  primaryCta: Cta;
  navItems: NavItem[];
}

const { businessName, logoPath, logoAlt, phone, primaryCta, navItems } =
  Astro.props;
const telHref = phone ? `tel:${phone.replace(/[^+\d]/g, "")}` : "";
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header
  class="site-header sticky top-0 z-[700] bg-white/95 backdrop-blur supports-[backdrop-filter]:bg-white/85 border-b border-[rgb(var(--color-border))] transition-transform duration-200 ease-[cubic-bezier(0.22,0.61,0.36,1)]"
  data-header
>
  <Container>
    <div class="flex items-center justify-between gap-6 h-[68px] md:h-[76px]">
      <Logo
        businessName={businessName}
        logoPath={logoPath}
        logoAlt={logoAlt}
        size="md"
      />

      <nav class="hidden md:block" aria-label="Pagrindinis meniu">
        <ul class="flex items-center gap-7 lg:gap-9">
          {navItems.map((item) => {
            const itemPath = item.href.replace(/\/$/, "") || "/";
            const isActive = itemPath === currentPath;
            return (
              <li>
                <a
                  href={item.href}
                  class={`relative inline-block py-2 text-[0.9375rem] font-semibold tracking-[-0.005em] transition-colors ${
                    isActive
                      ? "text-[rgb(var(--color-accent))] after:absolute after:left-0 after:right-0 after:-bottom-1 after:h-[2px] after:rounded-full after:bg-[rgb(var(--color-accent))]"
                      : "text-[rgb(var(--color-text))]/75 hover:text-[rgb(var(--color-accent))]"
                  }`}
                  aria-current={isActive ? "page" : undefined}
                >
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>

      <div class="hidden md:flex items-center gap-5">
        {phone && (
          <a
            href={telHref}
            class="inline-flex items-center gap-2 text-[0.9375rem] font-semibold tracking-[-0.005em] text-[rgb(var(--color-text))] hover:text-[rgb(var(--color-accent))] hover:no-underline transition-colors"
          >
            <Icon name="phone" size={16} class="text-[rgb(var(--color-accent))]" />
            <span>{phone}</span>
          </a>
        )}
        <Button href={primaryCta.href} variant="primary" class="px-6 min-h-[46px] text-[0.9375rem]">
          {primaryCta.label}
        </Button>
      </div>

      <button
        type="button"
        class="menu-trigger md:hidden relative inline-flex items-center justify-center w-11 h-11 rounded-[14px] border border-[rgb(var(--color-border))] bg-white p-0 text-[rgb(var(--color-text))] cursor-pointer transition-[border-color,background-color,transform] duration-150 hover:border-[rgb(var(--color-text))]/40 active:scale-[0.96] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-accent))] focus-visible:ring-offset-2"
        aria-label="Atidaryti meniu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-menu-toggle
      >
        <span class="menu-trigger__bars relative block w-[18px] h-[14px]" aria-hidden="true">
          <span class="menu-trigger__bar"></span>
          <span class="menu-trigger__bar"></span>
          <span class="menu-trigger__bar"></span>
        </span>
      </button>
    </div>
  </Container>
</header>

<div
  id="mobile-menu"
  class="mobile-menu fixed inset-0 z-[1000] flex flex-col overflow-y-auto overscroll-contain bg-[rgb(var(--color-bg))] text-[rgb(var(--color-text))] opacity-0 invisible transition-[opacity,visibility] duration-200 ease-[cubic-bezier(0.22,0.61,0.36,1)] md:!hidden"
  data-mobile-menu
  role="dialog"
  aria-modal="true"
  aria-label="Pagrindinis meniu"
  aria-hidden="true"
>
  <div class="bg-[rgb(var(--color-bg))]">
    <Container>
      <div class="flex items-center justify-between gap-4 h-[68px]">
        <Logo
          businessName={businessName}
          logoPath={logoPath}
          logoAlt={logoAlt}
          size="md"
        />
        <button
          type="button"
          class="menu-trigger relative inline-flex items-center justify-center w-11 h-11 rounded-[14px] border border-[rgb(var(--color-border))] bg-white p-0 text-[rgb(var(--color-text))] cursor-pointer transition-[border-color,background-color,transform] duration-150 hover:border-[rgb(var(--color-text))]/40 active:scale-[0.96] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-accent))] focus-visible:ring-offset-2 is-open"
          aria-label="Užverti meniu"
          data-menu-close
        >
          <span class="menu-trigger__bars relative block w-[18px] h-[14px]" aria-hidden="true">
            <span class="menu-trigger__bar"></span>
            <span class="menu-trigger__bar"></span>
            <span class="menu-trigger__bar"></span>
          </span>
        </button>
      </div>
    </Container>
  </div>

  <Container>
    <div class="mobile-menu__body flex flex-col flex-1 pt-6 pb-8">
      <nav class="flex flex-col" aria-label="Mobiliojo įrenginio meniu">
        <ul class="flex flex-col list-none m-0 p-0">
          {navItems.map((item, index) => {
            const itemPath = item.href.replace(/\/$/, "") || "/";
            const isActive = itemPath === currentPath;
            return (
              <li
                class="mobile-menu__item border-b border-[rgb(var(--color-border))]/70 first:border-t first:border-[rgb(var(--color-border))]/70"
                style={`--stagger:${index * 60}ms`}
                data-menu-item
              >
                <a
                  href={item.href}
                  class={`group/link relative flex items-center justify-between gap-4 py-5 no-underline transition-colors hover:no-underline ${
                    isActive
                      ? "text-[rgb(var(--color-accent))]"
                      : "text-[rgb(var(--color-text))] hover:text-[rgb(var(--color-accent))]"
                  }`}
                  aria-current={isActive ? "page" : undefined}
                >
                  <span class="font-bold leading-[1.05] tracking-[-0.035em] text-[clamp(2rem,9vw,2.875rem)]">
                    {item.label}
                  </span>
                  <span
                    class={`shrink-0 inline-flex items-center justify-center w-7 h-7 rounded-full transition-all duration-200 ${
                      isActive
                        ? "bg-[rgb(var(--color-accent))] text-white opacity-100 translate-x-0"
                        : "bg-[rgb(var(--color-surface-alt))] text-[rgb(var(--color-text))]/60 opacity-0 -translate-x-1 group-hover/link:opacity-100 group-hover/link:translate-x-0"
                    }`}
                    aria-hidden="true"
                  >
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="5" y1="12" x2="19" y2="12" />
                      <polyline points="13 6 19 12 13 18" />
                    </svg>
                  </span>
                </a>
              </li>
            );
          })}
        </ul>
      </nav>

      <div
        class="mobile-menu__contact mt-auto pt-10"
        data-menu-contact
      >
        {phone && (
          <div class="flex flex-col gap-2 mb-5">
            <p class="m-0 text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-[rgb(var(--color-muted))]">
              Turite klausimų?
            </p>
            <a
              href={telHref}
              class="inline-block text-[1.75rem] font-bold leading-[1.1] tracking-[-0.02em] text-[rgb(var(--color-text))] hover:text-[rgb(var(--color-accent))] hover:no-underline transition-colors"
            >
              {phone}
            </a>
          </div>
        )}
        <Button href={primaryCta.href} variant="primary" size="lg" class="w-full">
          {primaryCta.label}
        </Button>
      </div>
    </div>
  </Container>
</div>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const closeBtn = document.querySelector<HTMLButtonElement>("[data-menu-close]");
  const menu = document.querySelector<HTMLDivElement>("[data-mobile-menu]");
  const header = document.querySelector<HTMLElement>("[data-header]");
  const body = document.body;

  let lastFocused: HTMLElement | null = null;

  function setMenuOpen(open: boolean) {
    if (!toggle || !menu) return;
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Užverti meniu" : "Atidaryti meniu");
    toggle.classList.toggle("is-open", open);
    menu.setAttribute("aria-hidden", String(!open));
    body.classList.toggle("is-menu-open", open);

    if (open) {
      lastFocused = document.activeElement as HTMLElement;
      requestAnimationFrame(() => closeBtn?.focus());
    } else {
      if (lastFocused && lastFocused !== document.body) {
        lastFocused.focus();
      } else {
        toggle.focus();
      }
    }
  }

  toggle?.addEventListener("click", () => {
    const isOpen = toggle.getAttribute("aria-expanded") === "true";
    setMenuOpen(!isOpen);
  });

  closeBtn?.addEventListener("click", () => setMenuOpen(false));

  // Close after any in-menu link click.
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => setMenuOpen(false));
  });

  // Close on ESC.
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && body.classList.contains("is-menu-open")) {
      setMenuOpen(false);
    }
  });

  // Close when viewport jumps back to desktop.
  const desktopMq = window.matchMedia("(min-width: 768px)");
  desktopMq.addEventListener("change", (ev) => {
    if (ev.matches) setMenuOpen(false);
  });

  // Mobile-only: hide header on scroll down, reveal on scroll up.
  // Disabled in capture mode and while menu is open.
  const mobileMq = window.matchMedia("(max-width: 767px)");
  const SCROLL_THRESHOLD = 8;
  const TOP_OFFSET = 16;
  let lastScrollY = window.scrollY;
  let ticking = false;

  function onScroll() {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      ticking = false;
      if (!header) return;
      if (!mobileMq.matches) {
        header.classList.remove("site-header--hidden");
        lastScrollY = window.scrollY;
        return;
      }
      if (body.classList.contains("capture-mode")) return;
      if (body.classList.contains("is-menu-open")) return;

      const y = window.scrollY;
      const delta = y - lastScrollY;

      if (y <= TOP_OFFSET) {
        header.classList.remove("site-header--hidden");
      } else if (delta > SCROLL_THRESHOLD) {
        header.classList.add("site-header--hidden");
      } else if (delta < -SCROLL_THRESHOLD) {
        header.classList.remove("site-header--hidden");
      }

      lastScrollY = y;
    });
  }

  window.addEventListener("scroll", onScroll, { passive: true });
</script>

<style>
  /* Capture mode: header is static so it doesn't overlap full-page screenshots. */
  :global(body.capture-mode) .site-header {
    position: static;
    transform: none !important;
  }

  /* ─────────────────────────────────────────────────────────────────
     Menu trigger — 3-line hamburger that morphs into an X.
     Same component is used for both open and close (with .is-open).
     ───────────────────────────────────────────────────────────────── */
  .menu-trigger__bars {
    /* Container for the three bars; height tunes the gap between lines. */
  }
  .menu-trigger__bar {
    position: absolute;
    left: 0;
    width: 100%;
    height: 1.75px;
    background-color: currentColor;
    border-radius: 2px;
    transition:
      transform 200ms cubic-bezier(0.22, 0.61, 0.36, 1),
      opacity 140ms cubic-bezier(0.22, 0.61, 0.36, 1),
      top 200ms cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  .menu-trigger__bar:nth-child(1) { top: 0; }
  .menu-trigger__bar:nth-child(2) { top: calc(50% - 0.875px); }
  .menu-trigger__bar:nth-child(3) { top: calc(100% - 1.75px); }

  /* Open state: top → +45°, middle → fade, bottom → −45° */
  .menu-trigger.is-open .menu-trigger__bar:nth-child(1) {
    top: calc(50% - 0.875px);
    transform: rotate(45deg);
  }
  .menu-trigger.is-open .menu-trigger__bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0.4);
  }
  .menu-trigger.is-open .menu-trigger__bar:nth-child(3) {
    top: calc(50% - 0.875px);
    transform: rotate(-45deg);
  }

  /* ─────────────────────────────────────────────────────────────────
     Mobile menu items — staggered fade/translate on open.
     The menu open state itself is toggled via body.is-menu-open in
     global.css (cross-component rule).
     ───────────────────────────────────────────────────────────────── */
  [data-mobile-menu] [data-menu-item] {
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 280ms cubic-bezier(0.22, 0.61, 0.36, 1),
      transform 280ms cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  [data-mobile-menu] [data-menu-contact] {
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 320ms cubic-bezier(0.22, 0.61, 0.36, 1),
      transform 320ms cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  :global(body.is-menu-open) [data-mobile-menu] [data-menu-item] {
    opacity: 1;
    transform: translateY(0);
    transition-delay: var(--stagger, 0ms);
  }
  :global(body.is-menu-open) [data-mobile-menu] [data-menu-contact] {
    opacity: 1;
    transform: translateY(0);
    /* Reveal after the last nav link */
    transition-delay: 260ms;
  }

  /* Reduced motion: instant menu, no stagger, no hamburger morph anim. */
  @media (prefers-reduced-motion: reduce) {
    .site-header,
    [data-mobile-menu],
    [data-mobile-menu] [data-menu-item],
    [data-mobile-menu] [data-menu-contact],
    .menu-trigger__bar {
      transition: none !important;
    }
    [data-mobile-menu] [data-menu-item],
    [data-mobile-menu] [data-menu-contact] {
      opacity: 1;
      transform: none;
    }
  }
</style>
