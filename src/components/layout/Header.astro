---
import Logo from "@/components/ui/Logo.astro";
import Button from "@/components/ui/Button.astro";
import Container from "@/components/ui/Container.astro";
import type { NavItem } from "@/data/navigation";
import type { Cta } from "@/data/business";

interface Props {
  businessName: string;
  logoPath: string | null;
  logoAlt: string;
  phone: string;
  primaryCta: Cta;
  navItems: NavItem[];
}

const { businessName, logoPath, logoAlt, phone, primaryCta, navItems } =
  Astro.props;

const telHref = phone ? `tel:${phone.replace(/[^+\d]/g, "")}` : "";
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class="site-header" data-header>
  <Container>
    <div class="site-header__inner">
      <Logo
        businessName={businessName}
        logoPath={logoPath}
        logoAlt={logoAlt}
        size="md"
      />

      <nav class="site-header__nav" aria-label="Pagrindinis meniu">
        <ul class="site-header__nav-list">
          {navItems.map((item) => {
            const itemPath = item.href.replace(/\/$/, "") || "/";
            const isActive = itemPath === currentPath;
            return (
              <li>
                <a
                  href={item.href}
                  class={`site-header__nav-link ${isActive ? "is-active" : ""}`}
                  aria-current={isActive ? "page" : undefined}
                >
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>

      <div class="site-header__actions">
        {phone && (
          <a href={telHref} class="site-header__phone">
            <span aria-hidden="true">📞</span>
            <span>{phone}</span>
          </a>
        )}
        <Button href={primaryCta.href} variant="primary">
          {primaryCta.label}
        </Button>
      </div>

      <button
        type="button"
        class="site-header__toggle"
        aria-label="Atidaryti meniu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-menu-toggle
      >
        <span class="site-header__toggle-bar"></span>
        <span class="site-header__toggle-bar"></span>
        <span class="site-header__toggle-bar"></span>
      </button>
    </div>

    <div
      id="mobile-menu"
      class="mobile-menu"
      aria-hidden="true"
      data-mobile-menu
    >
      <ul class="mobile-menu__list">
        {navItems.map((item) => {
          const itemPath = item.href.replace(/\/$/, "") || "/";
          const isActive = itemPath === currentPath;
          return (
            <li>
              <a
                href={item.href}
                class={`mobile-menu__link ${isActive ? "is-active" : ""}`}
                aria-current={isActive ? "page" : undefined}
              >
                {item.label}
              </a>
            </li>
          );
        })}
        {phone && (
          <li>
            <a href={telHref} class="mobile-menu__link mobile-menu__link--phone">
              <span aria-hidden="true">📞</span> {phone}
            </a>
          </li>
        )}
        <li class="mobile-menu__cta">
          <Button href={primaryCta.href} variant="primary">
            {primaryCta.label}
          </Button>
        </li>
      </ul>
    </div>
  </Container>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const menu = document.querySelector<HTMLDivElement>("[data-mobile-menu]");
  const header = document.querySelector<HTMLElement>("[data-header]");

  function setMenuOpen(open: boolean) {
    if (!toggle || !menu || !header) return;
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Užverti meniu" : "Atidaryti meniu");
    menu.setAttribute("aria-hidden", String(!open));
    header.classList.toggle("is-menu-open", open);
  }

  toggle?.addEventListener("click", () => {
    const isOpen = toggle.getAttribute("aria-expanded") === "true";
    setMenuOpen(!isOpen);
  });

  // Close menu after clicking a link
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => setMenuOpen(false));
  });

  // Close on Esc
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") setMenuOpen(false);
  });

  // Reset state if user resizes back to desktop
  const desktopMq = window.matchMedia("(min-width: 768px)");
  desktopMq.addEventListener("change", (ev) => {
    if (ev.matches) setMenuOpen(false);
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 700;
    background-color: var(--color-white);
    border-bottom: 1px solid var(--color-border);
  }
  /* Capture mode: header is static so full-page screenshots don't show
     the sticky bar overlapping the middle of the page. Toggle via
     business.ts -> captureMode: true. */
  :global(body.capture-mode) .site-header {
    position: static;
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-lg);
    height: 72px;
  }

  .site-header__nav { display: none; }
  .site-header__actions { display: none; }

  .site-header__toggle {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0;
  }
  .site-header__toggle-bar {
    display: block;
    width: 20px;
    height: 2px;
    background-color: var(--color-text);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .site-header.is-menu-open .site-header__toggle-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .site-header.is-menu-open .site-header__toggle-bar:nth-child(2) {
    opacity: 0;
  }
  .site-header.is-menu-open .site-header__toggle-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-menu {
    display: none;
    padding-block: var(--spacing-md) var(--spacing-lg);
    border-top: 1px solid var(--color-border);
  }
  .site-header.is-menu-open .mobile-menu {
    display: block;
  }
  .mobile-menu__list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }
  .mobile-menu__link {
    display: block;
    padding: 0.7rem 0.5rem;
    font-size: var(--font-size-lg);
    font-weight: 500;
    color: var(--color-text);
    border-radius: var(--radius-sm);
  }
  .mobile-menu__link:hover { text-decoration: none; background-color: var(--color-bg-alt); }
  .mobile-menu__link.is-active {
    color: var(--color-primary);
    font-weight: 600;
  }
  .mobile-menu__link--phone {
    color: var(--color-primary);
    font-weight: 600;
  }
  .mobile-menu__cta {
    margin-top: var(--spacing-sm);
  }
  .mobile-menu__cta :global(.btn) { width: 100%; }

  @media (min-width: 768px) {
    .site-header__inner { height: 80px; }
    .site-header__toggle { display: none; }
    .mobile-menu { display: none !important; }

    .site-header__nav { display: block; }
    .site-header__nav-list {
      display: flex;
      gap: var(--spacing-lg);
    }
    .site-header__nav-link {
      color: var(--color-text);
      font-weight: 500;
      padding: 0.5rem 0;
      position: relative;
      transition: color var(--motion-duration-fast) var(--motion-ease);
    }
    .site-header__nav-link:hover {
      color: var(--color-primary);
      text-decoration: none;
    }
    .site-header__nav-link.is-active { color: var(--color-primary); }
    .site-header__nav-link.is-active::after {
      content: "";
      position: absolute;
      left: 0; right: 0; bottom: -2px;
      height: 2px;
      background-color: var(--color-primary);
      border-radius: 1px;
    }

    .site-header__actions {
      display: flex;
      align-items: center;
      gap: var(--spacing-md);
    }
    .site-header__phone {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: var(--color-text);
      font-weight: 600;
      font-size: var(--font-size-base);
      transition: color var(--motion-duration-fast) var(--motion-ease);
    }
    .site-header__phone:hover { color: var(--color-primary); text-decoration: none; }
  }

  @media (min-width: 1024px) {
    .site-header__nav-list { gap: var(--spacing-xl); }
  }
</style>
