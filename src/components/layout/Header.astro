---
import Logo from "@/components/ui/Logo.astro";
import Button from "@/components/ui/Button.astro";
import Container from "@/components/ui/Container.astro";
import type { NavItem } from "@/data/navigation";
import type { Cta } from "@/data/business";

interface Props {
  businessName: string;
  logoPath: string | null;
  logoAlt: string;
  phone: string;
  primaryCta: Cta;
  navItems: NavItem[];
}

const { businessName, logoPath, logoAlt, phone, primaryCta, navItems } =
  Astro.props;
const telHref = phone ? `tel:${phone.replace(/[^+\d]/g, "")}` : "";
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header
  class="site-header sticky top-0 z-[700] bg-white/95 backdrop-blur supports-[backdrop-filter]:bg-white/85 border-b border-[rgb(var(--color-border))] transition-transform duration-200 ease-[cubic-bezier(0.22,0.61,0.36,1)]"
  data-header
>
  <Container>
    <div class="flex items-center justify-between gap-6 h-[72px] md:h-[80px]">
      <Logo
        businessName={businessName}
        logoPath={logoPath}
        logoAlt={logoAlt}
        size="md"
      />

      <nav class="hidden md:block" aria-label="Pagrindinis meniu">
        <ul class="flex items-center gap-8 lg:gap-10">
          {navItems.map((item) => {
            const itemPath = item.href.replace(/\/$/, "") || "/";
            const isActive = itemPath === currentPath;
            return (
              <li>
                <a
                  href={item.href}
                  class={`relative inline-block py-2 font-medium transition-colors ${
                    isActive
                      ? "text-[rgb(var(--color-accent))] after:absolute after:left-0 after:right-0 after:-bottom-0.5 after:h-0.5 after:rounded-sm after:bg-[rgb(var(--color-accent))]"
                      : "text-[rgb(var(--color-text))] hover:text-[rgb(var(--color-accent))]"
                  }`}
                  aria-current={isActive ? "page" : undefined}
                >
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>

      <div class="hidden md:flex items-center gap-4">
        {phone && (
          <a
            href={telHref}
            class="inline-flex items-center gap-2 font-semibold text-[rgb(var(--color-text))] hover:text-[rgb(var(--color-accent))] hover:no-underline transition-colors"
          >
            <span aria-hidden="true">📞</span>
            <span>{phone}</span>
          </a>
        )}
        <Button href={primaryCta.href} variant="primary">
          {primaryCta.label}
        </Button>
      </div>

      <button
        type="button"
        class="md:hidden inline-flex flex-col items-center justify-center gap-[5px] w-11 h-11 rounded-xl border border-[rgb(var(--color-border))] bg-white p-0 cursor-pointer transition-[border-color,background-color] hover:border-[rgb(var(--color-border-strong))] hover:bg-[rgb(var(--color-surface-alt))] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-accent))] focus-visible:ring-offset-2"
        aria-label="Atidaryti meniu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-menu-toggle
      >
        <span class="block w-5 h-0.5 rounded-sm bg-[rgb(var(--color-text))]"></span>
        <span class="block w-5 h-0.5 rounded-sm bg-[rgb(var(--color-text))]"></span>
        <span class="block w-5 h-0.5 rounded-sm bg-[rgb(var(--color-text))]"></span>
      </button>
    </div>
  </Container>
</header>

<div
  id="mobile-menu"
  class="fixed inset-0 z-[1000] flex flex-col overflow-y-auto overscroll-contain bg-[rgb(var(--color-bg))] text-[rgb(var(--color-text))] opacity-0 invisible transition-[opacity,visibility] duration-200 ease-[cubic-bezier(0.22,0.61,0.36,1)] md:!hidden"
  data-mobile-menu
  role="dialog"
  aria-modal="true"
  aria-label="Pagrindinis meniu"
  aria-hidden="true"
>
  <div class="bg-[rgb(var(--color-bg))]">
    <Container>
      <div class="flex items-center justify-between gap-4 h-[72px]">
        <Logo
          businessName={businessName}
          logoPath={logoPath}
          logoAlt={logoAlt}
          size="md"
        />
        <button
          type="button"
          class="inline-flex items-center justify-center w-11 h-11 rounded-full border border-[rgb(var(--color-border-strong))] bg-transparent text-[rgb(var(--color-text))] cursor-pointer transition-[border-color,background-color,color,transform] hover:bg-[rgb(var(--color-text))] hover:text-[rgb(var(--color-bg))] hover:border-[rgb(var(--color-text))] active:scale-[0.97] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-accent))] focus-visible:ring-offset-2"
          aria-label="Užverti meniu"
          data-menu-close
        >
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="6" y1="6" x2="18" y2="18"></line>
            <line x1="18" y1="6" x2="6" y2="18"></line>
          </svg>
        </button>
      </div>
    </Container>
  </div>

  <Container>
    <div class="flex flex-col flex-1 gap-12 py-10">
      <nav class="flex flex-col gap-4" aria-label="Mobiliojo įrenginio meniu">
        <p class="m-0 text-xs font-semibold uppercase tracking-[0.18em] text-[rgb(var(--color-muted))]" aria-hidden="true">
          Naršymas
        </p>
        <ul class="flex flex-col list-none m-0 p-0 border-t border-[rgb(var(--color-border))]">
          {navItems.map((item, index) => {
            const itemPath = item.href.replace(/\/$/, "") || "/";
            const isActive = itemPath === currentPath;
            const num = String(index + 1).padStart(2, "0");
            return (
              <li
                class="border-b border-[rgb(var(--color-border))] opacity-0 translate-y-2"
                style={`--stagger:${index * 40}ms`}
                data-menu-item
              >
                <a
                  href={item.href}
                  class={`relative flex items-baseline gap-4 py-5 no-underline transition-colors hover:no-underline ${
                    isActive
                      ? "text-[rgb(var(--color-accent))] after:content-[''] after:absolute after:left-0 after:-bottom-px after:w-8 after:h-0.5 after:rounded-sm after:bg-[rgb(var(--color-accent))]"
                      : "text-[rgb(var(--color-text))] hover:text-[rgb(var(--color-accent))]"
                  }`}
                  aria-current={isActive ? "page" : undefined}
                >
                  <span
                    class={`shrink-0 w-7 text-xs font-medium tracking-[0.18em] tabular-nums ${
                      isActive ? "text-[rgb(var(--color-accent))]" : "text-[rgb(var(--color-muted))]"
                    }`}
                    aria-hidden="true"
                  >
                    {num}
                  </span>
                  <span class="font-bold leading-[1.08] tracking-[-0.035em] text-[clamp(1.875rem,8.5vw,2.75rem)]">
                    {item.label}
                  </span>
                </a>
              </li>
            );
          })}
        </ul>
      </nav>

      <div class="mt-auto flex flex-col gap-4 p-6 rounded-2xl bg-[rgb(var(--color-surface-alt))] border border-[rgb(var(--color-border))]">
        {phone && (
          <div class="flex flex-col gap-0.5">
            <p class="m-0 text-xs font-semibold uppercase tracking-[0.18em] text-[rgb(var(--color-muted))]">
              Turite klausimų?
            </p>
            <a
              href={telHref}
              class="inline-block text-2xl font-bold leading-tight tracking-tight text-[rgb(var(--color-accent))] hover:text-[rgb(var(--color-accent-dark))] hover:no-underline"
            >
              {phone}
            </a>
          </div>
        )}
        <Button href={primaryCta.href} variant="primary" size="lg" class="w-full">
          {primaryCta.label}
        </Button>
      </div>
    </div>
  </Container>
</div>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const closeBtn = document.querySelector<HTMLButtonElement>("[data-menu-close]");
  const menu = document.querySelector<HTMLDivElement>("[data-mobile-menu]");
  const header = document.querySelector<HTMLElement>("[data-header]");
  const body = document.body;

  let lastFocused: HTMLElement | null = null;

  function setMenuOpen(open: boolean) {
    if (!toggle || !menu) return;
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Užverti meniu" : "Atidaryti meniu");
    menu.setAttribute("aria-hidden", String(!open));
    body.classList.toggle("is-menu-open", open);

    if (open) {
      lastFocused = document.activeElement as HTMLElement;
      requestAnimationFrame(() => closeBtn?.focus());
    } else {
      if (lastFocused && lastFocused !== document.body) {
        lastFocused.focus();
      } else {
        toggle.focus();
      }
    }
  }

  toggle?.addEventListener("click", () => {
    const isOpen = toggle.getAttribute("aria-expanded") === "true";
    setMenuOpen(!isOpen);
  });

  closeBtn?.addEventListener("click", () => setMenuOpen(false));

  // Close after any in-menu link click.
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => setMenuOpen(false));
  });

  // Close on ESC.
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && body.classList.contains("is-menu-open")) {
      setMenuOpen(false);
    }
  });

  // Close when viewport jumps back to desktop.
  const desktopMq = window.matchMedia("(min-width: 768px)");
  desktopMq.addEventListener("change", (ev) => {
    if (ev.matches) setMenuOpen(false);
  });

  // Mobile-only: hide header on scroll down, reveal on scroll up.
  // Disabled in capture mode and while menu is open.
  const mobileMq = window.matchMedia("(max-width: 767px)");
  const SCROLL_THRESHOLD = 8;
  const TOP_OFFSET = 16;
  let lastScrollY = window.scrollY;
  let ticking = false;

  function onScroll() {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      ticking = false;
      if (!header) return;
      if (!mobileMq.matches) {
        header.classList.remove("site-header--hidden");
        lastScrollY = window.scrollY;
        return;
      }
      if (body.classList.contains("capture-mode")) return;
      if (body.classList.contains("is-menu-open")) return;

      const y = window.scrollY;
      const delta = y - lastScrollY;

      if (y <= TOP_OFFSET) {
        header.classList.remove("site-header--hidden");
      } else if (delta > SCROLL_THRESHOLD) {
        header.classList.add("site-header--hidden");
      } else if (delta < -SCROLL_THRESHOLD) {
        header.classList.remove("site-header--hidden");
      }

      lastScrollY = y;
    });
  }

  window.addEventListener("scroll", onScroll, { passive: true });
</script>

<style>
  /* Capture mode: header is static so it doesn't overlap full-page screenshots. */
  :global(body.capture-mode) .site-header {
    position: static;
    transform: none !important;
  }

  /* Reduced motion: skip stagger and hide-on-scroll transition. */
  @media (prefers-reduced-motion: reduce) {
    .site-header,
    [data-mobile-menu],
    [data-mobile-menu] [data-menu-item] {
      transition: none !important;
    }
    [data-mobile-menu] [data-menu-item] {
      opacity: 1;
      transform: none;
    }
  }
</style>
