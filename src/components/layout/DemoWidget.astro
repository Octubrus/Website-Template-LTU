---
import Icon from "@/components/ui/Icon.astro";
import { agency } from "@/data/agency";

const ksMark = agency.name
  .split(/\s+/)
  .map((word) => word.charAt(0))
  .slice(0, 2)
  .join("")
  .toUpperCase();
---

<a
  class="demo-widget group fixed z-[900] flex no-underline transition-[transform,box-shadow,background-color,border-color,opacity] duration-200 ease-out
         bottom-[calc(var(--mobile-cta-height,56px)+0.5rem)] right-3 max-w-none flex-row items-center gap-2 rounded-full px-3.5 py-1.5
         md:bottom-6 md:right-6 md:max-w-[280px] md:flex-col md:items-stretch md:gap-1.5 md:rounded-2xl md:px-4 md:py-3.5
         bg-[rgb(var(--ks-navy))] text-white border border-[rgb(var(--ks-gold))]/35
         shadow-[0_18px_50px_rgb(7_17_31/0.28)] hover:shadow-[0_22px_60px_rgb(7_17_31/0.4)]
         hover:-translate-y-0.5 hover:bg-[rgb(var(--ks-navy-soft))] hover:border-[rgb(var(--ks-gold))]/70
         focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--ks-gold))] focus-visible:ring-offset-2"
  href={agency.website}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={`${agency.ctaLabel} su ${agency.name}`}
>
  <span class="flex items-center gap-2">
    <span
      class="inline-flex items-center justify-center w-[22px] h-[22px] md:w-[26px] md:h-[26px] rounded-md bg-[rgb(var(--ks-gold))] text-[rgb(var(--ks-navy))] text-[0.65rem] md:text-[0.7rem] font-extrabold tracking-[0.04em] shrink-0"
      aria-hidden="true"
    >
      {ksMark}
    </span>
    <span class="text-[0.65rem] md:text-[0.7rem] font-bold uppercase tracking-[0.12em] text-[rgb(var(--ks-muted))]">
      Demo versija
    </span>
  </span>

  <span class="hidden md:block text-sm leading-snug text-[rgb(var(--ks-cream))]">
    Paruošė <strong class="font-bold text-white">{agency.name}</strong>
  </span>

  <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-[rgb(var(--ks-gold))] group-hover:text-[rgb(var(--ks-gold-hover))] md:mt-0.5">
    {agency.ctaLabel}
    <Icon name="arrow-right" size={14} strokeWidth={2} class="transition-transform group-hover:translate-x-0.5" />
  </span>
</a>

<style>
  /* Hide entirely in capture mode — clean prospect-facing screenshots. */
  :global(body.capture-mode) .demo-widget {
    display: none;
  }

  /* Hide on very narrow viewports — footer demo credit carries the brand. */
  @media (max-width: 359px) {
    .demo-widget { display: none; }
  }

  /* Subtle on-load entrance. */
  @media (prefers-reduced-motion: no-preference) {
    .demo-widget {
      animation: demo-widget-in 0.45s cubic-bezier(0.22, 0.61, 0.36, 1) 0.5s both;
    }
  }
  @keyframes demo-widget-in {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
