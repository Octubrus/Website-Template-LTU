---
import Logo from "@/components/ui/Logo.astro";
import Container from "@/components/ui/Container.astro";
import { agency } from "@/data/agency";
import type { NavItem } from "@/data/navigation";

interface Props {
  businessName: string;
  logoPath: string | null;
  logoAlt: string;
  shortDescription: string;
  phone: string;
  email: string;
  address: string;
  facebookUrl?: string;
  demoMode: boolean;
  navItems: NavItem[];
}

const {
  businessName,
  logoPath,
  logoAlt,
  shortDescription,
  phone,
  email,
  address,
  facebookUrl,
  demoMode,
  navItems,
} = Astro.props;

const telHref = phone ? `tel:${phone.replace(/[^+\d]/g, "")}` : "";
const year = new Date().getFullYear();
const agencyHostname = agency.website
  .replace(/^https?:\/\//, "")
  .replace(/\/$/, "");
const ksMark = agency.name
  .split(/\s+/)
  .map((word) => word.charAt(0))
  .slice(0, 2)
  .join("")
  .toUpperCase();

const colHeading =
  "mb-4 text-sm font-bold uppercase tracking-[0.05em] text-[rgb(var(--color-text))]";
const colLink =
  "text-base text-[rgb(var(--color-text))] hover:text-[rgb(var(--color-accent))] transition-colors";
---

<footer class="bg-[rgb(var(--color-surface-alt))] text-[rgb(var(--color-text))] border-t border-[rgb(var(--color-border))] pt-16 pb-6">
  <Container>
    <div class="grid grid-cols-1 md:grid-cols-[1.6fr_1fr_1fr] gap-10 md:gap-12">
      <div>
        <Logo
          businessName={businessName}
          logoPath={logoPath}
          logoAlt={logoAlt}
          size="md"
        />
        <p class="mt-4 max-w-[42ch] text-[rgb(var(--color-muted))] leading-relaxed">
          {shortDescription}
        </p>
      </div>

      <nav aria-label="Apatinis meniu">
        <h3 class={colHeading}>Naršymas</h3>
        <ul class="flex flex-col gap-2.5">
          {navItems.map((item) => (
            <li>
              <a href={item.href} class={colLink}>{item.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <div>
        <h3 class={colHeading}>Kontaktai</h3>
        <ul class="flex flex-col gap-2.5">
          {phone && (
            <li><a href={telHref} class={colLink}>{phone}</a></li>
          )}
          {email && (
            <li><a href={`mailto:${email}`} class={colLink}>{email}</a></li>
          )}
          {address && (
            <li class="text-base text-[rgb(var(--color-muted))]">{address}</li>
          )}
          {facebookUrl && (
            <li>
              <a
                href={facebookUrl}
                target="_blank"
                rel="noopener noreferrer"
                class={colLink}
              >Facebook</a>
            </li>
          )}
        </ul>
      </div>
    </div>

    {demoMode && (
      <aside
        class="mt-10 grid grid-cols-[auto_1fr] md:grid-cols-[auto_1fr_auto] items-start md:items-center gap-x-6 gap-y-4 p-6 md:px-8 rounded-2xl bg-[rgb(var(--ks-navy))] text-[rgb(var(--ks-cream))] border border-[rgb(var(--ks-gold))]/25 leading-relaxed"
        data-reveal
        aria-label={`Demonstracinę svetainę paruošė ${agency.name}`}
      >
        <span
          class="inline-flex items-center justify-center w-11 h-11 rounded-xl bg-[rgb(var(--ks-gold))] text-[rgb(var(--ks-navy))] font-extrabold text-base tracking-[0.04em] shrink-0"
          aria-hidden="true"
        >
          {ksMark}
        </span>
        <div class="col-start-2 md:col-auto">
          <p class="font-semibold text-[rgb(var(--ks-white))] mb-1">
            Demonstracinę svetainę paruošė {" "}
            <a
              href={agency.website}
              target="_blank"
              rel="noopener noreferrer"
              class="font-bold text-[rgb(var(--ks-gold))] hover:text-[rgb(var(--ks-gold-hover))] hover:underline"
            >
              {agency.name}
            </a>.
          </p>
          <p class="text-sm leading-relaxed text-[rgb(var(--ks-muted))] max-w-[60ch]">
            {agency.description}
          </p>
        </div>
        <a
          href={agency.website}
          target="_blank"
          rel="noopener noreferrer"
          class="col-span-full md:col-auto justify-self-start text-sm font-bold text-[rgb(var(--ks-gold))] hover:text-[rgb(var(--ks-gold-hover))] hover:underline whitespace-nowrap"
        >
          {agencyHostname} <span aria-hidden="true">→</span>
        </a>
      </aside>
    )}

    <div class="mt-10 pt-4 border-t border-[rgb(var(--color-border))] text-sm text-[rgb(var(--color-muted))]">
      <p>© {year} {businessName}. Visos teisės saugomos.</p>
    </div>
  </Container>
</footer>
